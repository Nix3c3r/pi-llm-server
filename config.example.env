# pi-llm-server configuration
# /Edit this file before running `make install`.

# Linux user that should run llama-server
LLAMA_USER=pi

# Install location for llama.cpp
LLAMA_CPP_DIR=/opt/llama.cpp

# Where GGUF model files are stored
MODEL_DIR=/opt/llm-models

# Model download URL. Replace this with the exact GGUF file you want.
# Recommended starter: Qwen3-1.7B GGUF Q4_K_M or Q8_0 GGUF.
MODEL_URL=hf://lm-kit/qwen-3-1.7b-instruct-gguf/Qwen3-1.7B-Q4_K_M.gguf
MODEL_FILE=Qwen3-1.7B-Q4_K_M.gguf

# llama-server network settings
HOST=0.0.0.0
PORT=8080

# Runtime settings for Raspberry Pi 5
CONTEXT_SIZE=2048
THREADS=4

# Extra llama-server flags, optional
# Examples:
# EXTRA_ARGS="--verbose"
EXTRA_ARGS=
